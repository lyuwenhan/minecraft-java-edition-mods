{
	"schemaVersion": 1,
	"id": "auto-greeting",
	"version": "${version}",
	"name": "Auto Greeting",
	"description": "Automatically sends greeting messages when joining a server",
	"authors": [
		"Wenhan"
	],
	"environment": "*",
	"entrypoints": {
		"client": [
			"com.example.autogreeting.client.AutoGreetingClientMod"
		],
		"server": [
			"com.example.autogreeting.server.AutoGreetingServerMod"
		]
	},
	"mixins": [
		"auto-greeting.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.0",
		"fabric-api": "*",
		"minecraft": "1.21.11"
	}
}
